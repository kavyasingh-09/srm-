# PostgreSQL connection string
# Example (local): postgres://postgres:yourpassword@localhost:5432/campus_marketplace
DATABASE_URL=postgres://postgres:postgres@localhost:5432/campus_marketplace

# Set to true for hosted Postgres (Neon, Supabase, Railway, etc.)
DATABASE_SSL=false

# JWT secret — change this in production
JWT_SECRET=change-me-to-a-long-random-string

# API port
PORT=5000

# Frontend origin for CORS
CLIENT_ORIGIN=http://127.0.0.1:3000
