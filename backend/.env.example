# PostgreSQL connection string — paste from Neon Console → Connect → Connection string (pooled)
# Example: postgresql://neondb_owner:YOUR_PASSWORD@ep-cool-name-12345678.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT.region.aws.neon.tech/neondb?sslmode=require

# Required for Neon (must be true)
DATABASE_SSL=true

# JWT secret — change this in production
JWT_SECRET=change-me-to-a-long-random-string

# API port
PORT=5000

# Frontend origin for CORS
CLIENT_ORIGIN=http://127.0.0.1:3000
